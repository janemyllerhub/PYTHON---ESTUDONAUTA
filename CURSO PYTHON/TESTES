def media(a, b):
    m = (a+b) / 2
    if m >= 7:
        return "APROVADO"
    elif m == 6:
        return "RECUPERAÇÃO"
    elif m < 6:
        return "REPROVADO"
n1 = float(input('Qual a sua primeira nota? '))
n2 = float(input('Qual a sua segunda nota? '))
resultado = media(n1,n2)
print ('Sua situação atual é:', resultado) 
